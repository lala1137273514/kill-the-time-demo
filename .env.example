# Copy this file to `.env` (same folder) and fill in your key, then `npm start`.
# `.env` is gitignored — your key never gets committed. The shell environment
# always overrides these, so an exported var still wins.

# Bailian / DashScope API key — powers the glass-box voice remote:
#   - the orchestrator (qwen) that turns your words into an action
#   - text-to-speech narration (the pet speaking results)
# Get one at https://bailian.console.aliyun.com/  (key looks like sk-...)
BAILIAN_API_KEY=

# --- optional knobs (leave blank to use the in-app Settings / built-in defaults) ---
# CLAWD_ORCHESTRATOR_MODEL=qwen-plus
# CLAWD_WHISPER_MODEL=base
# CLAWD_GLASSBOX_HOTKEY=CommandOrControl+Space
# CLAWD_GLASSBOX_DISABLE=1   # set to fall back to vanilla Clawd (no input bar/voice)
